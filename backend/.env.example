# ── eSIM Access API Configuration ─────────────────────────────────────────────
# Get this from your eSIM Access dashboard account
ESIM_ACCESS_CODE=YOUR_ACCESS_CODE_HERE

# API Base URL (do not change unless instructed by eSIM Access)
ESIM_BASE_URL=https://api.esimaccess.com

# Request timeout in seconds
ESIM_TIMEOUT=30

# ── Optional Webhook Security ──────────────────────────────────────────────────
# Set this if eSIM Access provides a signing secret for webhook verification
ESIM_WEBHOOK_SECRET=

# ── CORS (your frontend URL) ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://eydost.az
